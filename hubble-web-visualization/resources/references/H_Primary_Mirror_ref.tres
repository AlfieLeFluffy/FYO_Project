[resource]
script = ExtResource("1_lovi3")
ref_name = "Primary Mirror"
ref_desc = "[b][color=light_blue]Section:[/color] 3.1, 3.7[/b]
The primary mirror is a 2.4m diameter hyperbolic mirror with with an alluminium and magnesium fluoride coating, designed for a broad light spetrum.
The maximum tolerance error of the polish is about 10nm (1/65 lenght of IR). But an initial flaw, where the edges were about 1.2mm too flat rendered the beginning readings blurry. More can be found in section 3.7."
wavelength_low = 115.0
wavelength_high = 1700.0
metadata/_custom_type_script = "uid://chyrk1ts4wb7h"
