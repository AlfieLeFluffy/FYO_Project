ref_name = "Wide Field Camera 3"
ref_desc = "[b][color=light_blue]Section:[/color] 3.3[/b]
The WFC3 is, unlike the name suggest, a fourth genenration instrument onboard. It has two main channels for visible light and infra-red light and is one of the only deviced that can work with IR light."
wavelength_low = 200.0
wavelength_high = 1700.0
