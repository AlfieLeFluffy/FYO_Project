[resource]
script = ExtResource("1_lmjee")
ref_name = "MIRI"
ref_desc = "[b][color=light_blue]Section:[/color] 4.3[/b]
The Mid Infra-Red Instrument is a multifunction instrument that work with mid infra-red light. As other insturment only work in near IR, the MIRI is covering most of the functionalities of others within mid IR. From imaging and coronography to spectrography."
wavelength_low = 500.0
wavelength_high = 2800.0
